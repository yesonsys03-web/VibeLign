{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-minimize",
    "core:window:allow-close",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [{ "path": "**/.vibelign/reports/**" }]
    },
    "dialog:default",
    "process:default",
    "store:allow-load",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "updater:default"
  ]
}
