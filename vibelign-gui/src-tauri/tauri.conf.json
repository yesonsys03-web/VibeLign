{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vibelign-gui",
  "version": "2.0.30",
  "identifier": "com.vibelign.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "VibeLign",
        "width": 900,
        "height": 680,
        "minWidth": 720,
        "minHeight": 540,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "vib-runtime/**/*"
    ]
  }
}
